# PostgreSQL — local: docker compose up -d db | cloud: Supabase connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careff"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/careff"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (optional — error tracking activates only if DSN is set)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
