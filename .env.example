# PostgreSQL — local: docker compose up -d db | cloud: Supabase connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careff"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/careff"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (optional — error tracking activates only if DSN is set)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Mission Control (optional — centralized monitoring dashboard).
# Register this project in the dashboard ("+ Agregar proyecto" with the URL of
# this app's /api/health), copy the API key it shows once, and set both below.
# With them set, the logger ships warn/error to Mission Control's /api/ingest.
# The /api/health polling needs nothing here.
MISSION_CONTROL_URL=""
MISSION_CONTROL_API_KEY=""
# Release tag attached to error reports for deploy correlation. Optional —
# falls back to a git SHA env var, then the package version.
APP_RELEASE=""

# Geo providers (optional — default to the free public instances).
# GEOREF_URL: Argentine government geocoder (primary, free, no key).
# NOMINATIM_URL: OSM geocoder, used as fallback for POIs / outside Argentina.
# OSRM_URL: driving-distance matrix. Point at self-hosted instances for scale.
GEOREF_URL="https://apis.datos.gob.ar/georef/api"
NOMINATIM_URL="https://nominatim.openstreetmap.org"
OSRM_URL="https://router.project-osrm.org"

# Fuel price auto-suggest (optional — Secretaría de Energía open data, free, no key).
# Used to pre-fill the trip expense estimator. The resource id changes when the
# dataset is republished; override ENERGIA_FUEL_RESOURCE to keep it working.
ENERGIA_API_URL="https://datos.energia.gob.ar/api/3/action"
ENERGIA_FUEL_RESOURCE="80ac25de-a44a-4445-9215-090cf55cfda5"
